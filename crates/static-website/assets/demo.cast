[16.124361, "o", "\r\u001b[7m  -H \"Content-Type: application/json\" \\\u001b[27m\r\n\r\u001b[7m  -H \"Authorization: Bearer $OPENAI_API_KEY\" \\\u001b[27m\r\n\r\u001b[7m  -d '{\u001b[27m\r\n\r\u001b[7m    \"model\": \"gpt-5\",\u001b[27m\r\n\r\u001b[7m    \"messages\": [\u001b[27m\r\n\r\u001b[7m      {\u001b[27m\r\n\r\u001b[7m        \"role\": \"user\",\u001b[27m\r\n\r\u001b[7m        \"content\":\u001b[27m\r\n\r\u001b[7m        \"Give me the average tempature day by day in london for the last 7 days.\"\u001b[27m\r\n\r\u001b[7m      }\u001b[27m\r\n\r\u001b[7m    ]\u001b[27m\r\n\r\u001b[7m  }' | jq -r '.choices[0].message.content'\u001b[27m\r\n\r"]
[16.649442, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[C\u001b[Ccurl https://api.openai.com/v1/chat/completions \\\r\n\r  -s \\\r\n\r  -H \"Content-Type: application/json\" \\\r\n\r  -H \"Authorization: Bearer $OPENAI_API_KEY\" \\\r\n\r  -d '{\r\n\r    \"model\": \"gpt-5\",\r\n\r    \"messages\": [\r\n\r      {\r\n\r        \"role\": \"user\",\r\n\r        \"content\":\r\n\r        \"Give me the average tempature day by day in london for the last 7 days.\"\r\n\r      }\r\n\r    ]\r\n"]
[16.649565, "o", "\r  }' | jq -r '.choices[0].message.content'\r\n\r\u001b[A\r\n\u001b[?2004l\r"]
